generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  password     String?
  company      String?
  phone        String?
  slug         String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  role         String        @default("admin")
  clientId     String?       @unique
  clientLink   Client?       @relation("ClientPortalUser", fields: [clientId], references: [id], onDelete: SetNull)

  products      Product[]
  categories    Category[]
  clients       Client[]
  sales         Sale[]
  priceLists    PriceList[]
  requests      ProductRequest[]
  notifications Notification[]
  mlConnection  MLConnection?
  settings      Settings?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // low_stock, ml_question, new_sale, etc.
  severity  String   @default("info") // info, warning, danger, success
  title     String
  body      String?
  link      String?

  // FK opcional al recurso que originó la notificación, para dedup y navegación
  resourceType String?
  resourceId   String?

  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, resourceType, resourceId])
}

model Settings {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  exchangeRate    Float     @default(0)
  autoUpdateRate  Boolean   @default(true)
  lastRateUpdate  DateTime?

  eurExchangeRate    Float     @default(0)
  autoUpdateEurRate  Boolean   @default(true)
  lastEurRateUpdate  DateTime?

  primaryCurrency String    @default("USD")

  defaultMargin   Float     @default(0.15)

  waPhoneNumber   String?
  waApiToken      String?
  waWebhookSecret String?

  mlAutoAnswer    Boolean   @default(false)
  mlAutoSync      Boolean   @default(true)
  mlSyncInterval  Int       @default(60)

  notifLowStock   Boolean   @default(true)
  notifNewQuestion Boolean  @default(true)
  notifNewSale    Boolean   @default(false)

  updatedAt       DateTime  @updatedAt
}

model Product {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  sku           String
  name          String
  description   String?
  category      String?
  categoryId    String?
  categoryRel   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand         String?
  unit          String       @default("unidad")
  images        String[]

  costUSD       Float        @default(0)
  priceUSD      Float
  priceBs       Float        @default(0)
  marginPercent Float        @default(0)

  stock         Int          @default(0)
  stockMin      Int          @default(5)
  stockMax      Int?

  mlItemId      String?
  mlStatus      String?
  mlCategoryId  String?
  mlListingType String       @default("gold_special")
  mlSyncEnabled Boolean      @default(false)
  mlLastSync    DateTime?

  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  saleItems     SaleItem[]
  mlQuestions   MLQuestion[]
  priceListItems PriceListItem[]
  requestItems  ProductRequestItem[]

  @@unique([userId, sku])
  @@index([userId])
  @@index([categoryId])
}

model Category {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  description String?
  color       String?
  icon        String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)

  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")

  products    Product[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, slug])
  @@index([userId])
  @@index([parentId])
}

model Client {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  company        String?
  phone          String?
  email          String?
  address        String?
  city           String?
  type           String    @default("retail")
  notes          String?

  totalPurchases Float     @default(0)
  lastPurchase   DateTime?

  priceListId    String?
  priceList      PriceList? @relation(fields: [priceListId], references: [id], onDelete: SetNull)

  portalUser     User?     @relation("ClientPortalUser")
  requests       ProductRequest[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sales          Sale[]

  @@index([userId])
}

model PriceList {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  notes     String?
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     PriceListItem[]
  clients   Client[]

  @@unique([userId, name])
  @@index([userId])
}

model PriceListItem {
  id          String    @id @default(cuid())
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  priceUSD    Float

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([priceListId, productId])
  @@index([productId])
}

model ProductRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // status: pending | partially_paid | paid | released | cancelled
  status      String   @default("pending")
  notes       String?
  totalUSD    Float    @default(0)
  paidUSD     Float    @default(0)

  fulfilledAt DateTime?
  releasedAt  DateTime?

  saleId      String?  @unique
  sale        Sale?    @relation("RequestRelease", fields: [saleId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       ProductRequestItem[]
  payments    Payment[]

  @@index([userId, status])
  @@index([clientId])
  @@index([createdAt])
}

model Payment {
  id           String   @id @default(cuid())
  requestId    String
  request      ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  amountUSD    Float
  amountBs     Float    @default(0)
  exchangeRate Float    @default(0)

  // method: cash_usd | cash_bs | zelle | binance | transfer_bs | transfer_usd | other
  method       String
  // origin: portal | admin (quién lo registró)
  origin       String   @default("portal")
  reference    String?  // últimos 4 dígitos, número de transacción, etc.
  proofUrl     String?  // URL al comprobante (screenshot, PDF, etc.)
  note         String?

  // status: submitted | verified | rejected
  status       String   @default("submitted")
  verifiedAt   DateTime?
  verifiedBy   String?
  rejectedReason String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([requestId, status])
  @@index([createdAt])
}

model ProductRequestItem {
  id          String         @id @default(cuid())
  requestId   String
  request     ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId   String
  product     Product        @relation(fields: [productId], references: [id])

  quantity    Int
  priceUSD    Float
  subtotalUSD Float
}

model Sale {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?    @relation(fields: [clientId], references: [id])

  channel       String
  mlOrderId     String?

  subtotalUSD   Float
  totalUSD      Float
  totalBs       Float      @default(0)
  exchangeRate  Float

  paymentMethod String     @default("cash_usd")
  paymentStatus String     @default("paid")

  notes         String?
  status        String     @default("completed")

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  items         SaleItem[]
  releasedFrom  ProductRequest? @relation("RequestRelease")

  @@index([userId])
  @@index([createdAt])
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])

  quantity    Int
  priceUSD    Float
  subtotalUSD Float
}

model MLConnection {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  mlUserId     String
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  siteId       String       @default("MLV")

  isActive     Boolean      @default(true)
  connectedAt  DateTime     @default(now())
  lastSync     DateTime?

  questions    MLQuestion[]
}

model MLQuestion {
  id            String       @id @default(cuid())
  mlQuestionId  String       @unique
  connectionId  String
  connection    MLConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?     @relation(fields: [productId], references: [id])

  mlItemId      String
  questionText  String
  buyerNickname String?
  status        String       @default("unanswered")

  answerText    String?
  answeredAt    DateTime?
  answeredBy    String?
  aiSuggestion  String?

  createdAt     DateTime     @default(now())

  @@index([connectionId, status])
}

model ExchangeRateLog {
  id        String   @id @default(cuid())
  rate      Float
  source    String   @default("bcv")
  currency  String   @default("USD")
  createdAt DateTime @default(now())

  @@index([currency, createdAt])
}

model QuickReply {
  id        String   @id @default(cuid())
  userId    String
  trigger   String
  reply     String
  createdAt DateTime @default(now())

  @@index([userId])
}
